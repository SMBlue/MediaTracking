generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // App-specific
  createdAt     DateTime @default(now())
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application models

model Client {
  id          String   @id @default(cuid())
  name        String
  nameAliases String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  mbas              MBA[]
  detectedInvoices  Invoice[] @relation("DetectedClient")
}

model MBA {
  id        String    @id @default(cuid())
  clientId  String
  mbaNumber String    @unique
  name      String
  budget    Decimal   @db.Decimal(15, 2)
  currency  String    @default("USD")
  startDate DateTime  @db.Date
  endDate   DateTime  @db.Date
  status    MBAStatus @default(ACTIVE)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Client payment tracking
  clientPaid       Boolean   @default(false)
  clientPaidDate   DateTime? @db.Date
  clientPaidAmount Decimal?  @db.Decimal(15, 2)

  netsuiteProjectNumber String?

  // Concur integration
  concurProjectId          String?   // UUID from Concur List Item API (level-2)
  concurProjectCode        String?   // level-2 shortCode (the project, e.g., "695055")
  concurClientCode         String?   // level-1 shortCode (the client, e.g., "270709")
  concurProjectOfficeCode  String?   // level-3 shortCode (project office, e.g., "5")
  concurSyncStatus         String?   // SYNCED, FAILED, etc.

  // Contract email ingestion (source tracking)
  contractEmailId          String?   // Gmail messageId of the contract email
  contractAttachmentId     String?   // Gmail attachmentId of the specific PDF
  contractParsedAt         DateTime?
  contractParseConfidence  Float?

  // Persisted contract PDF (Supabase Storage: mba-contracts bucket)
  contractPdfPath          String?   // object key within bucket, e.g. "<mbaId>/<filename>.pdf"
  contractPdfFilename      String?   // original filename from Gmail
  contractPdfSize          Int?      // bytes
  contractPdfUploadedAt    DateTime?

  @@index([contractEmailId, contractAttachmentId])

  client              Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  invoiceAllocations  InvoiceAllocation[]
  changeOrders        ChangeOrder[]
  creditsOut          CreditRollover[]    @relation("CreditsOut")
  creditsIn           CreditRollover[]    @relation("CreditsIn")
  vendorLineItems     VendorInvoiceLineItem[]
  reconciliation      ReconciliationRecord?
  netsuiteInvoices    NetsuiteClientInvoice[]
}

enum MBAStatus {
  DRAFT
  ACTIVE
  RECONCILING
  CLOSED
}

enum Platform {
  GOOGLE_ADS
  META
  BING
  TIKTOK
  LINKEDIN
  OTHER
}

model Invoice {
  id            String        @id @default(cuid())
  vendor        Platform
  invoiceNumber String
  invoiceDate   DateTime      @db.Date
  totalAmount   Decimal       @db.Decimal(15, 2)
  currency      String        @default("USD")
  type          InvoiceType   @default(INVOICE)
  status        InvoiceStatus @default(CONFIRMED)
  sourceType    InvoiceSource @default(MANUAL)
  isPaid        Boolean       @default(false)
  paidDate      DateTime?     @db.Date
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Email ingestion fields
  emailMessageId  String?   @unique
  emailSubject    String?
  emailReceivedAt DateTime?
  parseConfidence Float?
  parseErrors     String?

  // Parsed entity hints (surfaced from ingestion; user-correctable on detail page)
  detectedClientId   String?
  detectedClientName String?
  detectedVendorName String?

  // Concur integration
  concurInvoiceId     String?          @unique // PaymentRequestId from Concur
  concurSyncStatus    ConcurSyncStatus @default(NOT_SYNCED)
  concurLastSyncAt    DateTime?
  concurLastSyncError String?

  allocations   InvoiceAllocation[]
  lineItems     VendorInvoiceLineItem[]
  detectedClient Client? @relation("DetectedClient", fields: [detectedClientId], references: [id], onDelete: SetNull)

  @@unique([vendor, invoiceNumber])
  @@index([detectedClientId])
}

enum InvoiceStatus {
  DRAFT
  CONFIRMED
}

enum InvoiceSource {
  MANUAL
  CSV_UPLOAD
  EMAIL_PARSED
}

enum InvoiceType {
  INVOICE
  CREDIT_NOTE
}

model InvoiceAllocation {
  id        String   @id @default(cuid())
  invoiceId String
  mbaId     String
  amount    Decimal  @db.Decimal(15, 2)
  createdAt DateTime @default(now())

  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  mba       MBA      @relation(fields: [mbaId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, mbaId])
}

// Audit trail for tracking changes
model AuditLog {
  id         String   @id @default(cuid())
  entityType String   // "MBA", "Invoice", "Client"
  entityId   String
  action     String   // "CREATE", "UPDATE", "DELETE"
  changes    Json?    // { field: { old: x, new: y } }
  userId     String?
  userEmail  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model ChangeOrder {
  id            String   @id @default(cuid())
  mbaId         String
  amount        Decimal  @db.Decimal(15, 2)
  description   String
  effectiveDate DateTime @db.Date
  netsuiteRef   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  mba MBA @relation(fields: [mbaId], references: [id], onDelete: Cascade)
}

model CreditRollover {
  id          String       @id @default(cuid())
  fromMbaId   String
  toMbaId     String
  amount      Decimal      @db.Decimal(15, 2)
  type        RolloverType
  description String?
  netsuiteRef String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  fromMba MBA @relation("CreditsOut", fields: [fromMbaId], references: [id], onDelete: Cascade)
  toMba   MBA @relation("CreditsIn", fields: [toMbaId], references: [id], onDelete: Cascade)
}

enum RolloverType {
  JOURNAL_ENTRY
  CREDIT_MEMO
  CASH_CREDIT
}

model VendorInvoiceLineItem {
  id           String   @id @default(cuid())
  invoiceId    String
  campaignName String
  platform     String?
  amount       Decimal  @db.Decimal(15, 2)
  mbaId        String?
  confidence   Float?
  createdAt    DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  mba     MBA?    @relation(fields: [mbaId], references: [id], onDelete: SetNull)
}

model ReconciliationRecord {
  id           String        @id @default(cuid())
  mbaId        String        @unique
  status       ReconStatus   @default(PENDING)
  finalBalance Decimal?      @db.Decimal(15, 2)
  outcome      ReconOutcome?
  rolloverId   String?
  notes        String?
  confirmedBy  String?
  confirmedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  mba MBA @relation(fields: [mbaId], references: [id], onDelete: Cascade)
}

enum ReconStatus {
  PENDING
  IN_REVIEW
  CONFIRMED
  CLOSED
}

enum ReconOutcome {
  REFUND
  ROLLOVER
  CLOSED_ZERO
}

model EmailSyncLog {
  id              String   @id @default(cuid())
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  emailsFound     Int      @default(0)
  emailsProcessed Int      @default(0)
  invoicesCreated Int      @default(0)
  errors          String?
  status          String   @default("RUNNING") // RUNNING, COMPLETED, FAILED

  @@index([startedAt])
}

model NetsuiteSyncLog {
  id              String   @id @default(cuid())
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  mbasChecked     Int      @default(0)
  paymentsUpdated Int      @default(0)
  rolloversCreated Int     @default(0)
  errors          String?
  status          String   @default("RUNNING") // RUNNING, COMPLETED, FAILED

  @@index([startedAt])
}

model NetsuiteClientInvoice {
  id                String   @id @default(cuid())
  mbaId             String
  netsuiteId        String   @unique // NS internal transaction ID for dedup
  invoiceNumber     String
  invoiceDate       DateTime @db.Date
  amount            Decimal  @db.Decimal(15, 2)
  status            String   // Open, Paid In Full, etc.
  paidDate          DateTime? @db.Date
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  mba MBA @relation(fields: [mbaId], references: [id], onDelete: Cascade)

  @@index([mbaId])
}

// Concur integration

enum ConcurSyncStatus {
  NOT_SYNCED
  PENDING
  SYNCED
  SYNC_FAILED
  PAYMENT_RECEIVED
}

model ConcurToken {
  id           String   @id @default(cuid())
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  geolocation  String   // e.g. https://us2.api.concursolutions.com
  updatedAt    DateTime @updatedAt
}

model ConcurSyncLog {
  id           String   @id @default(cuid())
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  invoicesPushed    Int @default(0)
  projectsSynced    Int @default(0)
  paymentsUpdated   Int @default(0)
  errors       String?
  status       String   @default("RUNNING") // RUNNING, COMPLETED, FAILED

  @@index([startedAt])
}
